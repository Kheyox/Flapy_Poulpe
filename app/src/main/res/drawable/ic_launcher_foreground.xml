<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Ambient Shadow under the Octopus -->
    <path
        android:fillType="nonZero"
        android:pathData="M 32 75 C 32 71, 76 71, 76 75 C 76 79, 32 79, 32 75 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="75"
                android:gradientRadius="22">
                <item android:offset="0.0" android:color="#4D000000"/>
                <item android:offset="1.0" android:color="#00000000"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- 4 Curvy Tentacles -->
    <!-- Left Tentacle 1 -->
    <path
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M 38 64 Q 32 74, 35 84 Q 36 86, 38 86">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="38"
                android:startY="64"
                android:endX="35"
                android:endY="86"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF7675"/>
                <item android:offset="1.0" android:color="#D63031"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Tentacle 2 (Inner Left) -->
    <path
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:pathData="M 46 66 Q 42 78, 48 86 Q 49 88, 51 86">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="46"
                android:startY="66"
                android:endX="48"
                android:endY="86"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF7675"/>
                <item android:offset="1.0" android:color="#D63031"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Tentacle 3 (Inner Right) -->
    <path
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:pathData="M 62 66 Q 66 78, 60 86 Q 59 88, 57 86">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="62"
                android:startY="66"
                android:endX="60"
                android:endY="86"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF7675"/>
                <item android:offset="1.0" android:color="#D63031"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right Tentacle 4 -->
    <path
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M 70 64 Q 76 74, 73 84 Q 72 86, 70 86">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="70"
                android:startY="64"
                android:endX="73"
                android:endY="86"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF7675"/>
                <item android:offset="1.0" android:color="#D63031"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Main Cute Bulbous Octopus Head (Rosé Neon to Deep Red) -->
    <path
        android:pathData="M 54 24 C 38 24, 30 36, 30 52 C 30 64, 40 68, 54 68 C 68 68, 78 64, 78 52 C 78 36, 70 24, 54 24 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="24"
                android:endX="54"
                android:endY="68"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF7675"/>
                <item android:offset="1.0" android:color="#D63031"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Under-Eyes Cute Pink Blush (Left & Right) -->
    <path android:fillColor="#4DFF7675" android:pathData="M 37 54 C 37 52, 43 52, 43 54 C 43 56, 37 56, 37 54 Z"/>
    <path android:fillColor="#4DFF7675" android:pathData="M 65 54 C 65 52, 71 52, 71 54 C 71 56, 65 56, 65 54 Z"/>

    <!-- Left Eye Outer (White) -->
    <path android:fillColor="#FFFFFF" android:pathData="M 44 43 C 40.7 43, 38 45.7, 38 49 C 38 52.3, 40.7 55, 44 55 C 47.3 55, 50 52.3, 50 49 C 50 45.7, 47.3 43, 44 43 Z" />
    <!-- Left Pupil & Highlight -->
    <path android:fillColor="#1E272E" android:pathData="M 45 46 C 43.3 46, 42 47.3, 42 49 C 42 50.7, 43.3 52, 45 52 C 46.7 52, 48 50.7, 48 49 C 48 47.3, 46.7 46, 45 46 Z" />
    <path android:fillColor="#FFFFFF" android:pathData="M 46.5 47.5 C 46 47.5, 45.5 48, 45.5 48.5 C 45.5 49, 46 49.5, 46.5 49.5 C 47 49.5, 47.5 49, 47.5 48.5 C 47.5 48, 47 47.5, 46.5 47.5 Z" />

    <!-- Right Eye Outer (White) -->
    <path android:fillColor="#FFFFFF" android:pathData="M 64 43 C 60.7 43, 58 45.7, 58 49 C 58 52.3, 60.7 55, 64 55 C 67.3 55, 70 52.3, 70 49 C 70 45.7, 67.3 43, 64 43 Z" />
    <!-- Right Pupil & Highlight -->
    <path android:fillColor="#1E272E" android:pathData="M 65 46 C 63.3 46, 62 47.3, 62 49 C 62 50.7, 63.3 52, 65 52 C 66.7 52, 68 50.7, 68 49 C 68 47.3, 66.7 46, 65 46 Z" />
    <path android:fillColor="#FFFFFF" android:pathData="M 66.5 47.5 C 66 47.5, 65.5 48, 65.5 48.5 C 65.5 49, 66 49.5, 66.5 49.5 C 67 49.5, 67.5 49, 67.5 48.5 C 67.5 48, 67 47.5, 66.5 47.5 Z" />

    <!-- Cute Happy Open Mouth -->
    <path
        android:fillColor="#1E272E"
        android:pathData="M 51 57 Q 54 62, 57 57 Z" />

    <!-- Deep Sea Tiny Bubbles (Accent Graphics) -->
    <path
        android:strokeWidth="1.5"
        android:strokeColor="#80FFFFFF"
        android:pathData="M 24 38 A 3 3 0 1 1 24 32 A 3 3 0 1 1 24 38 Z" />
    <path
        android:strokeWidth="1"
        android:strokeColor="#40FFFFFF"
        android:pathData="M 28 30 A 1.5 1.5 0 1 1 28 27 A 1.5 1.5 0 1 1 28 30 Z" />
    <path
        android:strokeWidth="1.2"
        android:strokeColor="#80FFFFFF"
        android:pathData="M 82 48 A 2 2 0 1 1 82 44 A 2 2 0 1 1 82 48 Z" />
    <path
        android:strokeWidth="1"
        android:strokeColor="#40FFFFFF"
        android:pathData="M 85 41 A 1 1 0 1 1 85 39 A 1 1 0 1 1 85 41 Z" />

</vector>
